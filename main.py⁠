# 4. சிக்னல் ஹிஸ்டரியை எடுத்து காட்டும் கமாண்ட்
@bot.message_handler(commands=['history'])
def show_history(message):
    conn = sqlite3.connect('trading_history.db')
    cursor = conn.cursor()
    cursor.execute('SELECT pair, timeframe, signal, confidence, timestamp FROM history ORDER BY id DESC LIMIT 5')
    rows = cursor.fetchall()
    conn.close()
    
    if not rows:
        bot.send_message(message.chat.id, "❌ இன்னும் எந்த சிக்னல் ஹிஸ்டரியும் சேமிக்கப்படவில்லை.")
        return
        
    history_msg = "📜 *கடைசி 5 சிக்னல்களின் விபரங்கள் (History):*\n\n"
    for row in rows:
        history_msg += f"📊 {row[0]} | ⏰ {row[1]}\n"
        history_msg += f"🚀 Signal: {row[2]}\n"
        history_msg += f"🎯 Accuracy: {row[3]}% | 📅 {row[4]}\n"
        history_msg += f"━━━━━━━━━━━━━━━━━━━━\n"
        
    bot.send_message(message.chat.id, history_msg, parse_mode="Markdown")
