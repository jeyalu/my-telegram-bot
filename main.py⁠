# சிக்னல் ஹிஸ்டரி சேமிக்க Database செட்டப் செய்தல்
def init_db():
    conn = sqlite3.connect('trading_history.db')
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            pair TEXT,
            timeframe TEXT,
            signal TEXT,
            confidence INTEGER,
            strength TEXT,
            timestamp TEXT
        )
    ''')
    conn.commit()
    conn.close()

init_db()

